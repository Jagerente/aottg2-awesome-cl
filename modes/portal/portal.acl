extension TeleportGUI
{
    Title = "Teleport";
    Width = 200;
    Height = 600;
    _inited = false;
    _opened = false;

    _tpZones = Dict();

    function Initialize()
    {
        UI.CreatePopup(self.Title, self.Title, self.Width, self.Height);

        for (obj in Map.FindMapObjectsByComponent("TeleportReference"))
        {
            c = obj.GetComponent("TeleportReference");
            self._tpZones.Set(obj.Name, c);
        }

        keys = self._tpZones.Keys;
        keys.Sort();
        for (k in keys)
        {
            c = self._tpZones.Get(k);
            UI.AddPopupButton(self.Title, c.MapObject.Name, c.MapObject.Name);
        }


        self._inited = true;
    }

    function ShowUI()
    {
        UI.ShowPopup(self.Title);
        self._opened = true;
    }

    function HideUI()
    {
        UI.HidePopup(self.Title);
        self._opened = false;
    }

    function OnButtonClick(btn)
    {
        if (!self._inited)
        {
            return;
        }

        if (btn == "Back")
        {
            self._opened = false;
            return;
        }

        c = self._tpZones.Get(btn, null);
        if (c == null)
        {
            return;
        }

        c.Teleport(PlayerProxy.GetCharacter(), true);
    }
}

