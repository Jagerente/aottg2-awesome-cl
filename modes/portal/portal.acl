        obj = Map.FindMapObjectByName(self._name);
        self._activatable = obj.GetComponent("Activatable");
    }

    coroutine Start()
    {
        Cutscene.HideDialogue();

        self.InitActivatable();

        # icon = IconEnum.TITAN16;
