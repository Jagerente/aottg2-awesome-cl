    }
}

extension ObjectPoolManager
{
    LASER = 1;
    HARD_LIGHT_BRIDGE = 2;
    TURRET_LASER = 3;

    _pools = Dict();
    _inited = false;

    function Initialize()
    {
        self._pools = Dict();
        self._inited = true;
    }

    # @param objectType int
    # @param templateObject MapObject
    # @param poolSize int
    function CreatePool(objectType, templateObject, poolSize)
    {
        if (!self._inited)
        {
            self.Initialize();
        }

        if (!self._pools.Contains(objectType))
        {
            pool = List();
            for (i in Range(0, poolSize, 1))
            {
                obj = Map.CopyMapObject(templateObject, true);
                obj.Active = false;
                pool.Add(obj);
            }
            self._pools.Set(objectType, pool);
        }
    }

    function GetObjectFromPool(objectType)
    {
        if (!self._inited)
        {
            self.Initialize();
        }

        if (self._pools.Contains(objectType))
        {
            pool = self._pools.Get(objectType);
            for (obj in pool)
            {
                if (!obj.Active)
                {
                    obj.Active = true;
                    return obj;
                }
            }
        }
        return null;
    }

    function ReturnObjectToPool(objectType, obj)
    {
        if (!self._inited)
        {
            self.Initialize();
        }

        if (self._pools.Contains(objectType))
        {
            obj.Active = false;
            obj.Position = Vector3(0, -9999, 0);
        }
    }

    function ClearPool(objectType)
    {
        if (!self._inited)
        {
            self.Initialize();
        }
        
        if (self._pools.Contains(objectType))
        {
            pool = self._pools.Get(objectType);
            for (obj in pool)
            {
                obj.Active = false;
                obj.Position = Vector3(0, -9999, 0);
            }
        }
    }
}

extension ResetManager
{
    _resetables = Dict();

    function Add(k, v)
    {
        l = self._resetables.Get(k, List());
        l.Add(v);
        self._resetables.Set(k, l);
    }

    function Reset(k)
    {
        l = self._resetables.Get(k, null);
        if (l != null)
        {
            for (v in l)
            {
                v.Reset();
            }
        }
    }

    function ResetAll()
    {
        for (l in self._resetables.Values)
        {
            for (v in l)
            {
                v.Reset();
            }
        }
    }
}

extension CutsceneManager
{
    _timers = Dict();
    _timersToDelete = List();
    _cutscenesState = Dict();
    _cutscenesCanPlay = Dict();
    _timer = Timer(0.0);

    function Start(id, full)
    {
        Cutscene.Start(id, full);
    }

    function NewTimer(k, t)
    {
        timer = Timer(t);
        self._timers.Set(k, KVProxy(k, timer));
        return timer;
    }

    function Wait(t)
    {
        self._timer.Reset(t);
    }

    function ResetTimer()
    {
        self._timer.Reset(0.0);
    }

    function IsTimerDone()
    {
        return self._timer.IsDone();
    }

    function GetState(k)
    {
        return self._cutscenesState.Get(k, 0);
    }
    
    function SetState(k, v)
    {
        return self._cutscenesState.Set(k, v);
    }
    
    function GetCanPlay(k)
    {
        return self._cutscenesCanPlay.Get(k, true);
    }
    
    function SetCanPlay(k, v)
    {
        return self._cutscenesCanPlay.Set(k, v);
    }

    function OnTick()
    {
        self._timer.UpdateOnTick();

        for (t in self._timers.Values)
        {
            t.Value.UpdateOnTick();
            if (t.Value.IsDone())
            {
                self._timersToDelete.Add(t);
            }
        }

        for (t in self._timersToDelete)
        {
            self._timers.Remove(t.Key);
        }

        self._timersToDelete.Clear();
    }

    function ResetAll()
    {
        self._cutscenesState.Clear();
        self._cutscenesCanPlay.Clear();
        self._timers.Clear();
    }
}

